{
  "name": "bilibili-danmu-claw-electron-app",
  "version": "0.3.1",
  "private": true,
  "description": "BiliBili AIĺĽąĺą•ĺ§¬",
  "author": "xgxdmx",
  "productName": "bilibili-danmu-claw",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "pnpm run build && pnpm run build:installer",
    "pack:mac": "pnpm run build && pnpm run build:installer:mac",
    "build:installer": "pnpm run prepare-deploy && pnpm exec electron-builder --projectDir ./.deploy --win nsis && node ../../scripts/finalize-electron-deploy.mjs",
    "build:installer:mac": "pnpm run prepare-deploy && pnpm exec electron-builder --projectDir ./.deploy --mac dmg zip && node ../../scripts/finalize-electron-deploy.mjs",
    "prepare-deploy": "node ../../scripts/prepare-electron-deploy.mjs"
  },
  "build": {
    "appId": "com.bilibili.danmu-claw",
    "productName": "BiliBili AIĺĽąĺą•ĺ§¬",
    "artifactName": "${productName} Setup.${ext}",
    "directories": {
      "output": "../../../dist"
    },
    "win": {
      "executableName": "bilibili-danmu-claw",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "resources/icon.ico",
      "category": "public.app-category.utilities"
    },
    "portable": {
      "artifactName": "${productName}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true,
      "include": "build/installer.nsh",
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "shortcutName": "BiliBili AIĺĽąĺą•ĺ§¬"
    },
    "afterPack": "build/afterPack.js",
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "../danmaku-core/runtime",
        "to": "danmaku-core",
        "filter": ["**/*"]
      },
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ]
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "electron": "41.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vue-tsc": "^2.2.0"
  }
}
