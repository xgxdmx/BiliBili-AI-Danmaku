# ============================================================
# pnpm 配置 - 项目本地隔离
# ============================================================

# 使用 pnpm 默认（isolated）模式，确保每个包生成完整 node_modules，便于 electron-builder 收集依赖
node-linker=isolated

# 将 pnpm store 固定到项目目录，避免在磁盘根目录创建 .pnpm-store
store-dir=.pnpm-store

# 严格 peer dependencies，避免隐式依赖
strict-peer-dependencies=false

# 批准构建脚本（Electron、esbuild 等需要 postinstall 脚本）
onlyBuiltDependencies="electron esbuild sharp @matrix-org/matrix-sdk-crypto-nodejs koffi protobufjs openclaw"

# 使用国内镜像加速（可选，如果在国内）
# registry=https://registry.npmmirror.com
